---
// /checkout — custom Stripe checkout page.
//
// Flow:
//   1. Visitor lands here from the sales-page popup with ?email=&first_name=
//   2. Page renders the order summary + Stripe Elements card form.
//   3. On submit, client uses Stripe.js to create a PaymentMethod from the card,
//      then POSTs to /api/checkout with { email, first_name, payment_method_id }.
//   4. /api/checkout creates a Stripe Customer, attaches the PaymentMethod with
//      setup_future_usage='off_session', confirms a PaymentIntent for the main
//      product, fires a GHL Inbound Webhook to tag the contact, and returns a
//      signed order token.
//   5. Browser redirects to /upsell?order=<token>.
//
// Copy is adapted from https://theparttimehypnotist.com/checkout-page-page
// (the legacy GHL checkout) and re-skinned in the PTH Design System.
import FunnelLayout from '../layouts/FunnelLayout.astro';

const publishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY || 'pk_test_PLACEHOLDER_REPLACE_ME';
const productName = import.meta.env.PRODUCT_MAIN_NAME || 'The Part-Time Hypnotist';
const productAmountCents = Number(import.meta.env.PRODUCT_MAIN_AMOUNT_CENTS || 1495);
const productAmount = (productAmountCents / 100).toFixed(2);
---
<FunnelLayout title="Secure Checkout · The Part-Time Hypnotist" mode="dark">
  <!-- Reassurance strip -->
  <section class="bg-pth-soft-ink border-b border-pth-rule-on-dark/60">
    <div class="max-w-5xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-xs md:text-sm text-pth-muted-on-dark">
      <span class="inline-flex items-center gap-2"><span class="text-pth-cyan font-bold">✓</span> 100% Secure Order</span>
      <span class="inline-flex items-center gap-2"><span class="text-pth-cyan font-bold">✓</span> 30-Day Results-First Guarantee</span>
      <span class="inline-flex items-center gap-2"><span class="text-pth-cyan font-bold">✓</span> 3 Free Bonuses · $314 Value</span>
    </div>
  </section>

  <!-- Hero copy -->
  <section class="max-w-5xl mx-auto px-4 pt-10 md:pt-14">
    <p class="eyebrow text-pth-cyan mb-3">YOU'RE ALMOST FINISHED</p>
    <h1 class="font-display text-3xl md:text-5xl font-bold uppercase tracking-tight text-pth-paper leading-tight">
      Lock in your <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(95deg,#00D6FF 0%,#2563EB 54%,#7B3DFF 100%);">$14.95</span> seat
    </h1>
    <p class="mt-4 text-pth-body-on-dark text-lg md:text-xl max-w-2xl">
      Enter your details below to get instant access to the full Part-Time Hypnotist training and all 3 bonuses.
    </p>
  </section>

  <!-- Two-column checkout layout -->
  <section class="max-w-5xl mx-auto px-4 pt-8 pb-16 grid md:grid-cols-5 gap-8">
    <!-- LEFT: form -->
    <form id="checkout-form" class="md:col-span-3 space-y-8" novalidate>
      <!-- Step 1: contact -->
      <div>
        <h2 class="font-display text-xl uppercase tracking-wide text-pth-paper mb-4 flex items-center gap-3">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-pth-brand-blue text-pth-paper text-sm">1</span>
          Contact information
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          <label class="flex flex-col gap-1.5">
            <span class="text-xs font-bold tracking-widest uppercase text-pth-muted-on-dark">First name</span>
            <input id="f-first-name" name="first_name" type="text" required autocomplete="given-name"
              class="bg-pth-soft-ink text-pth-paper border border-pth-rule-on-dark rounded px-4 py-3 text-base focus:outline-none focus:border-pth-cyan focus:ring-2 focus:ring-pth-cyan/30 transition" />
          </label>
          <label class="flex flex-col gap-1.5">
            <span class="text-xs font-bold tracking-widest uppercase text-pth-muted-on-dark">Email</span>
            <input id="f-email" name="email" type="email" required autocomplete="email"
              class="bg-pth-soft-ink text-pth-paper border border-pth-rule-on-dark rounded px-4 py-3 text-base focus:outline-none focus:border-pth-cyan focus:ring-2 focus:ring-pth-cyan/30 transition" />
          </label>
        </div>
      </div>

      <!-- Step 2: payment -->
      <div>
        <h2 class="font-display text-xl uppercase tracking-wide text-pth-paper mb-4 flex items-center gap-3">
          <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-pth-brand-blue text-pth-paper text-sm">2</span>
          Payment
        </h2>
        <div class="bg-pth-soft-ink border border-pth-rule-on-dark rounded p-4">
          <!-- Stripe Elements mounts here -->
          <div id="card-element" class="min-h-[44px]"></div>
        </div>
        <p id="card-errors" class="hidden mt-2 text-sm text-red-400" role="alert"></p>
        <p class="mt-3 text-xs text-pth-muted-on-dark">
          Your card details are handled directly by Stripe. We never see or store them on our servers.
        </p>
      </div>

      <!-- CTA -->
      <button type="submit" id="pay-btn"
        class="w-full font-display uppercase tracking-wider text-lg md:text-xl py-5 rounded-full transition disabled:opacity-60 disabled:cursor-not-allowed"
        style="background-image: linear-gradient(95deg,#FFC107 0%,#FF6B1A 100%); color:#1a1206; box-shadow: 0 8px 28px rgba(255,107,26,0.30);">
        <span data-idle>Send me the training — ${productAmount}</span>
        <span data-busy class="hidden">Processing…</span>
      </button>

      <p id="server-error" class="hidden text-center text-sm text-red-400" role="alert"></p>

      <p class="text-center text-xs text-pth-muted-on-dark">
        By placing this order you agree to our
        <a href="/terms" class="text-pth-cyan hover:underline">Terms</a> and
        <a href="/privacy" class="text-pth-cyan hover:underline">Privacy Policy</a>.
        <br />
        100% Secure &amp; Safe Payments · Powered by Stripe.
      </p>
    </form>

    <!-- RIGHT: order summary -->
    <aside class="md:col-span-2">
      <div class="sticky top-4 bg-pth-soft-ink border border-pth-rule-on-dark rounded-lg p-6 space-y-5">
        <h3 class="font-display text-base uppercase tracking-widest text-pth-muted-on-dark">Order summary</h3>

        <div class="flex items-start justify-between gap-4 border-b border-pth-rule-on-dark/60 pb-4">
          <div>
            <p class="text-pth-paper font-bold">{productName}</p>
            <p class="text-xs text-pth-muted-on-dark mt-1">Quantity: 1</p>
          </div>
          <p class="text-pth-paper font-bold whitespace-nowrap">${productAmount}</p>
        </div>

        <div class="space-y-2 text-sm text-pth-body-on-dark">
          <p class="font-bold text-pth-paper uppercase tracking-widest text-xs">Bonuses included</p>
          <ul class="space-y-1.5">
            <li class="flex gap-2"><span class="text-pth-cyan">✓</span> The Instant Client Campaign</li>
            <li class="flex gap-2"><span class="text-pth-cyan">✓</span> The Rapid Induction Formula Ebook</li>
            <li class="flex gap-2"><span class="text-pth-cyan">✓</span> The First Session Script Bundle</li>
          </ul>
        </div>

        <div class="flex items-center justify-between border-t border-pth-rule-on-dark/60 pt-4">
          <span class="font-display uppercase tracking-wider text-pth-paper">Order total</span>
          <span class="font-display text-2xl text-pth-paper">${productAmount}</span>
        </div>
      </div>

      <!-- Guarantee block -->
      <div class="mt-6 bg-pth-soft-ink-2 border border-pth-rule-on-dark rounded-lg p-5">
        <p class="font-display uppercase tracking-wider text-pth-paper text-base">Results-First Guarantee</p>
        <p class="mt-2 text-sm text-pth-body-on-dark">
          Try the training for 30 days. If you don't feel ready to take on your first paying client,
          email us for a full refund. No forms, no friction.
        </p>
      </div>
    </aside>
  </section>

  <!-- "Here's everything you're getting" recap (from legacy checkout copy) -->
  <section class="max-w-3xl mx-auto px-4 pb-20">
    <h2 class="font-display text-2xl md:text-3xl uppercase tracking-tight text-pth-paper text-center">
      Here's everything you're getting
    </h2>
    <ul class="mt-6 space-y-3 text-pth-body-on-dark text-base md:text-lg">
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> 6 "Rapid Relief" hypnotic tools that deliver client results fast — simple, fast-acting tools anyone can learn, even with zero hypnosis experience.</li>
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> The "Instant Client" system — three strategies Dan has used hundreds of times to land first clients locally.</li>
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> A full breakdown of how to run a 90-minute client session so you're never stuck wondering what to do.</li>
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> Real-world scripts for weight loss, smoking cessation, anxiety, and other in-demand niches.</li>
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> The "hybrid hypnosis" model used to sell $5,000 packages instead of $100/hr individual sessions.</li>
      <li class="flex gap-3"><span class="text-pth-cyan font-bold mt-1">✓</span> Instant access to the full training and all three bonuses.</li>
    </ul>
  </section>

  <!-- Stripe.js loader + Elements wiring -->
  <script is:inline src="https://js.stripe.com/v3/"></script>
  <script is:inline define:vars={{ publishableKey, productAmountCents }}>
  (function () {
    const form = document.getElementById('checkout-form');
    const cardErrors = document.getElementById('card-errors');
    const serverError = document.getElementById('server-error');
    const payBtn = document.getElementById('pay-btn');
    const firstNameEl = document.getElementById('f-first-name');
    const emailEl = document.getElementById('f-email');
    if (!form || !window.Stripe) return;

    // Pre-fill name + email from query string (handed off by the sales-page popup).
    try {
      const params = new URLSearchParams(window.location.search);
      const qFirst = params.get('first_name');
      const qEmail = params.get('email');
      if (qFirst && firstNameEl) firstNameEl.value = qFirst;
      if (qEmail && emailEl) emailEl.value = qEmail;
    } catch (_) {}

    const stripe = window.Stripe(publishableKey);
    const elements = stripe.elements();
    const card = elements.create('card', {
      style: {
        base: {
          color: '#F4F2EE',
          fontFamily: '"Atkinson Hyperlegible", Inter, system-ui, sans-serif',
          fontSize: '18px',
          '::placeholder': { color: '#A8B5CC' },
          iconColor: '#A8B5CC',
        },
        invalid: { color: '#E5484D', iconColor: '#E5484D' },
      },
    });
    card.mount('#card-element');

    card.on('change', e => {
      if (e.error) {
        cardErrors.textContent = e.error.message;
        cardErrors.classList.remove('hidden');
      } else {
        cardErrors.textContent = '';
        cardErrors.classList.add('hidden');
      }
    });

    function setBusy(busy) {
      const idle = payBtn.querySelector('[data-idle]');
      const b = payBtn.querySelector('[data-busy]');
      payBtn.disabled = busy;
      idle.classList.toggle('hidden', busy);
      b.classList.toggle('hidden', !busy);
    }

    form.addEventListener('submit', async e => {
      e.preventDefault();
      serverError.classList.add('hidden'); serverError.textContent = '';
      const first_name = (firstNameEl.value || '').trim();
      const email = (emailEl.value || '').trim();
      if (!first_name || !email) {
        serverError.textContent = 'Please fill in your name and email.';
        serverError.classList.remove('hidden');
        return;
      }

      setBusy(true);
      try {
        const pm = await stripe.createPaymentMethod({
          type: 'card',
          card,
          billing_details: { name: first_name, email },
        });
        if (pm.error) { throw new Error(pm.error.message || 'Card error'); }

        const r = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ first_name, email, payment_method_id: pm.paymentMethod.id }),
        });
        const data = await r.json().catch(() => ({}));
        if (!r.ok) { throw new Error(data.error || `Checkout failed (${r.status})`); }

        // If Stripe asks for 3DS, handle it here.
        if (data.requires_action && data.payment_intent_client_secret) {
          const action = await stripe.confirmCardPayment(data.payment_intent_client_secret);
          if (action.error) { throw new Error(action.error.message || 'Card authentication failed'); }
          // Re-call /api/checkout to finalize after action — simplest path is a second submit
          // with the same body. For brevity we assume 3DS-less test cards in placeholder mode.
        }

        if (!data.order_token) {
          throw new Error('Server did not return an order token.');
        }
        window.location.href = `/upsell?order=${encodeURIComponent(data.order_token)}`;
      } catch (e2) {
        serverError.textContent = e2.message || 'Something went wrong. Please try again.';
        serverError.classList.remove('hidden');
        setBusy(false);
      }
    });
  })();
  </script>
</FunnelLayout>
