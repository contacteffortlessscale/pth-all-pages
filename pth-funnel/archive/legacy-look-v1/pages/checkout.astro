---
// /checkout — legacy GHL style (BaseLayout: Inter / purple header / white body).
// Stripe Elements mounts inside a clean white card.
// All payment + API mechanics unchanged from the design-system version.
import BaseLayout from '../layouts/BaseLayout.astro';

const publishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY || 'pk_test_PLACEHOLDER_REPLACE_ME';
const productName = import.meta.env.PRODUCT_MAIN_NAME || 'The Part-Time Hypnotist';
const productAmountCents = Number(import.meta.env.PRODUCT_MAIN_AMOUNT_CENTS || 1495);
const productAmount = (productAmountCents / 100).toFixed(2);
---
<BaseLayout title="Secure Checkout · The Part-Time Hypnotist">
  <!-- Reassurance strip -->
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs md:text-sm text-slate-600">
      <span class="inline-flex items-center gap-2"><span class="text-pth-green text-lg">🔒</span> 100% Secure Order</span>
      <span class="inline-flex items-center gap-2"><span>🎁</span> 3 Free Bonuses · $314 Value</span>
      <span class="inline-flex items-center gap-2"><span>✅</span> 30-Day Money-Back Guarantee</span>
    </div>
  </section>

  <!-- Hero -->
  <section class="section bg-white pt-10 md:pt-14 pb-6">
    <div class="section-wide text-center">
      <p class="text-pth-blue font-bold text-sm md:text-base uppercase tracking-wide mb-3">🧠 The Part-Time Hypnotist</p>
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-3">
        You're Almost <span class="text-pth-blue">Finished...</span>
      </h1>
      <p class="text-base md:text-lg text-slate-600 max-w-2xl mx-auto">
        Enter your details below to get instant access to the full Part-Time Hypnotist training and all 3 bonuses.
      </p>
    </div>
  </section>

  <!-- Two-column checkout -->
  <section class="bg-white pb-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-5 gap-6 md:gap-8">
      <!-- LEFT: form -->
      <form id="checkout-form" class="md:col-span-3 space-y-6" novalidate>
        <!-- Step 1: contact -->
        <div class="bg-white border border-slate-200 rounded-lg p-5 md:p-6 shadow-sm">
          <h2 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-pth-blue text-white text-sm">1</span>
            Contact &amp; Shipping Information
          </h2>
          <div class="grid sm:grid-cols-2 gap-3">
            <label class="flex flex-col gap-1.5">
              <span class="text-xs font-bold uppercase tracking-wide text-slate-600">First name</span>
              <input id="f-first-name" name="first_name" type="text" required autocomplete="given-name"
                class="border border-slate-300 rounded-md px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-pth-blue focus:border-pth-blue transition" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-xs font-bold uppercase tracking-wide text-slate-600">Email</span>
              <input id="f-email" name="email" type="email" required autocomplete="email"
                class="border border-slate-300 rounded-md px-4 py-3 text-base focus:outline-none focus:ring-2 focus:ring-pth-blue focus:border-pth-blue transition" />
            </label>
          </div>
        </div>

        <!-- Step 2: payment -->
        <div class="bg-white border border-slate-200 rounded-lg p-5 md:p-6 shadow-sm">
          <h2 class="text-lg md:text-xl font-bold mb-4 flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-pth-blue text-white text-sm">2</span>
            Payment
          </h2>
          <div class="border border-slate-300 rounded-md p-4 bg-slate-50">
            <div id="card-element" class="min-h-[44px]"></div>
          </div>
          <p id="card-errors" class="hidden mt-2 text-sm text-pth-red" role="alert"></p>
          <p class="mt-3 text-xs text-slate-500">
            Your card details are handled directly by Stripe. We never see or store them on our servers.
          </p>
        </div>

        <!-- CTA -->
        <button type="submit" id="pay-btn"
          class="w-full bg-pth-orange hover:bg-pth-orange-dark text-white font-extrabold uppercase tracking-wide text-lg md:text-xl px-6 py-5 rounded-md shadow-lg transition disabled:opacity-60 disabled:cursor-not-allowed">
          <span data-idle>Send Me The Training — ${productAmount}</span>
          <span data-busy class="hidden">Processing…</span>
        </button>

        <p id="server-error" class="hidden text-center text-sm text-pth-red" role="alert"></p>

        <p class="text-center text-xs text-slate-500">
          By placing this order you agree to our
          <a href="/terms" class="text-pth-blue hover:underline">Terms</a> and
          <a href="/privacy" class="text-pth-blue hover:underline">Privacy Policy</a>.
          <br />
          * 100% Secure &amp; Safe Payments — Powered by Stripe *
        </p>
      </form>

      <!-- RIGHT: order summary -->
      <aside class="md:col-span-2">
        <div class="sticky top-4 bg-white border border-slate-200 rounded-lg p-5 shadow-sm space-y-4">
          <h3 class="text-sm font-bold uppercase tracking-wide text-slate-600">Order Summary</h3>

          <div class="flex items-start justify-between gap-4 border-b border-slate-200 pb-4">
            <div>
              <p class="font-bold text-slate-900">{productName}</p>
              <p class="text-xs text-slate-500 mt-1">Quantity: 1</p>
            </div>
            <p class="font-bold whitespace-nowrap">${productAmount}</p>
          </div>

          <div class="space-y-2 text-sm">
            <p class="font-bold uppercase tracking-wide text-xs text-slate-600">Bonuses included</p>
            <ul class="space-y-1.5 text-slate-700">
              <li class="flex gap-2"><span class="text-pth-green">✅</span> The Instant Client Campaign</li>
              <li class="flex gap-2"><span class="text-pth-green">✅</span> The Rapid Induction Formula Ebook</li>
              <li class="flex gap-2"><span class="text-pth-green">✅</span> The First Session Script Bundle</li>
            </ul>
          </div>

          <div class="flex items-center justify-between border-t border-slate-200 pt-4">
            <span class="font-bold uppercase tracking-wide">Order Total</span>
            <span class="font-extrabold text-2xl">${productAmount}</span>
          </div>
        </div>

        <!-- Guarantee -->
        <div class="mt-5 bg-slate-50 border border-slate-200 rounded-lg p-5">
          <p class="font-bold text-base mb-2">🛡 Results-First Guarantee</p>
          <p class="text-sm text-slate-700 leading-relaxed">
            Try the training for 30 days. If you don't feel ready to take on your first paying client,
            email us for a full refund. No forms, no friction.
          </p>
        </div>
      </aside>
    </div>
  </section>

  <!-- Recap: Here's everything you're getting -->
  <section class="section bg-slate-50">
    <div class="section-narrow">
      <h2 class="text-2xl md:text-4xl font-extrabold text-center mb-8">
        Here's Everything You're Getting
      </h2>
      <ul class="space-y-3 text-base md:text-lg leading-relaxed">
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>6 "Rapid Relief" hypnotic tools</strong> that deliver client results FAST — simple, fast-acting tools anyone can learn, even with zero hypnosis experience.</span></li>
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>My "Instant Client" system</strong> — three strategies Dan has used hundreds of times to land first clients locally.</span></li>
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>How to run a client session</strong> — a full breakdown of a 90-minute session so you're never stuck wondering what to do.</span></li>
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>Real-world scripts</strong> for weight loss, smoking cessation, anxiety, and other in-demand niches.</span></li>
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>The "hybrid hypnosis" model</strong> used to sell $5,000 packages instead of $100/hr individual sessions.</span></li>
        <li class="flex gap-3 items-start"><span class="text-pth-green text-xl flex-shrink-0">✅</span><span><strong>INSTANT access</strong> to the full training and all three bonuses.</span></li>
      </ul>
    </div>
  </section>

  <!-- Stripe.js + Elements -->
  <script is:inline src="https://js.stripe.com/v3/"></script>
  <script is:inline define:vars={{ publishableKey, productAmountCents }}>
  (function () {
    const form = document.getElementById('checkout-form');
    const cardErrors = document.getElementById('card-errors');
    const serverError = document.getElementById('server-error');
    const payBtn = document.getElementById('pay-btn');
    const firstNameEl = document.getElementById('f-first-name');
    const emailEl = document.getElementById('f-email');
    if (!form || !window.Stripe) return;

    try {
      const params = new URLSearchParams(window.location.search);
      const qFirst = params.get('first_name');
      const qEmail = params.get('email');
      if (qFirst && firstNameEl) firstNameEl.value = qFirst;
      if (qEmail && emailEl) emailEl.value = qEmail;
    } catch (_) {}

    const stripe = window.Stripe(publishableKey);
    const elements = stripe.elements();
    const card = elements.create('card', {
      style: {
        base: {
          color: '#0f172a',
          fontFamily: 'Inter, system-ui, sans-serif',
          fontSize: '16px',
          '::placeholder': { color: '#94a3b8' },
        },
        invalid: { color: '#e93d3d', iconColor: '#e93d3d' },
      },
    });
    card.mount('#card-element');

    card.on('change', e => {
      if (e.error) {
        cardErrors.textContent = e.error.message;
        cardErrors.classList.remove('hidden');
      } else {
        cardErrors.textContent = '';
        cardErrors.classList.add('hidden');
      }
    });

    function setBusy(busy) {
      const idle = payBtn.querySelector('[data-idle]');
      const b = payBtn.querySelector('[data-busy]');
      payBtn.disabled = busy;
      idle.classList.toggle('hidden', busy);
      b.classList.toggle('hidden', !busy);
    }

    form.addEventListener('submit', async e => {
      e.preventDefault();
      serverError.classList.add('hidden'); serverError.textContent = '';
      const first_name = (firstNameEl.value || '').trim();
      const email = (emailEl.value || '').trim();
      if (!first_name || !email) {
        serverError.textContent = 'Please fill in your name and email.';
        serverError.classList.remove('hidden');
        return;
      }

      setBusy(true);
      try {
        const pm = await stripe.createPaymentMethod({
          type: 'card', card,
          billing_details: { name: first_name, email },
        });
        if (pm.error) throw new Error(pm.error.message || 'Card error');

        const r = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ first_name, email, payment_method_id: pm.paymentMethod.id }),
        });
        const data = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(data.error || `Checkout failed (${r.status})`);

        if (data.requires_action && data.payment_intent_client_secret) {
          const action = await stripe.confirmCardPayment(data.payment_intent_client_secret);
          if (action.error) throw new Error(action.error.message || 'Card authentication failed');
        }
        if (!data.order_token) throw new Error('Server did not return an order token.');
        window.location.href = `/upsell?order=${encodeURIComponent(data.order_token)}`;
      } catch (e2) {
        serverError.textContent = e2.message || 'Something went wrong. Please try again.';
        serverError.classList.remove('hidden');
        setBusy(false);
      }
    });
  })();
  </script>
</BaseLayout>
