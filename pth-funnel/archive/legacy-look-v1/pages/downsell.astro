---
// /downsell — Live Client Recordings ($27 one-time).
// Legacy GHL style (BaseLayout: Inter / purple header / white body).
import BaseLayout from '../layouts/BaseLayout.astro';
import { verifyOrderToken } from '../lib/orderToken';

const orderToken = Astro.url.searchParams.get('order') || '';
const payload = orderToken ? verifyOrderToken(orderToken) : null;

const isPreview = Astro.url.searchParams.get('preview') === '1'
  && (import.meta.env.DEV || import.meta.env.ALLOW_PREVIEW_BYPASS === '1');

const downsellName = import.meta.env.PRODUCT_DOWNSELL_NAME || 'Live Client Recordings';
const downsellAmountCents = Number(import.meta.env.PRODUCT_DOWNSELL_AMOUNT_CENTS || 2700);
const downsellAmount = (downsellAmountCents / 100).toFixed(0);

if (!payload && !isPreview) {
  return Astro.redirect('/checkout');
}
---
<BaseLayout title={`Last Chance · ${downsellName}`}>
  {isPreview && (
    <div class="bg-pth-orange/15 border-b border-pth-orange/40">
      <div class="max-w-3xl mx-auto px-4 py-2.5 text-xs md:text-sm flex items-center justify-center gap-2 text-slate-700">
        <span class="font-bold uppercase tracking-widest text-pth-orange-dark">Preview mode</span>
        <span>— viewed without a real checkout. The Yes button won't charge.</span>
      </div>
    </div>
  )}

  <!-- Hero -->
  <section class="section bg-white pt-10 md:pt-14 pb-6">
    <div class="section-narrow text-center">
      <p class="text-pth-blue font-bold text-base md:text-lg mb-3 uppercase tracking-wide">⏳ One-Time Offer · Last Chance</p>
      <h1 class="text-2xl md:text-4xl font-extrabold leading-tight">
        Get My <span class="text-pth-blue">"Weird" $650/hr Sessions</span> For ${downsellAmount}?
      </h1>
      <p class="mt-4 text-base md:text-lg text-slate-700 leading-relaxed">
        Recordings of real client sessions Dan sold for $650/hr — watch over his shoulder and see exactly how the sessions are structured, how challenges get handled, and how transformations land. <strong>One click</strong> adds it to your order using the card you already entered.
      </p>
    </div>
  </section>

  <!-- Pitch detail -->
  <section class="section bg-slate-50">
    <div class="section-narrow">
      <p class="text-base md:text-lg text-slate-700 leading-relaxed mb-4">
        Most new hypnotists don't feel confident charging premium prices for their sessions. The best way I've found to help people get over this is to have my mentees watch over my shoulder in MY sessions. That way you can see what I'm actually delivering for $650/hr and think… <em>"hang on, I can do that too!"</em>
      </p>
      <p class="text-base md:text-lg text-slate-700 leading-relaxed">
        Get access to recordings of real client sessions sold for $650/hr, so you'll see step-by-step how Dan structures the sessions, handles challenges, and delivers "crying on the shoulder" transformations. <strong>Fair warning:</strong> Dan has a bit of a reputation for helping people with their weird sh*t that no one else can handle... and some of those are included for edu-tainment.
      </p>
    </div>
  </section>

  <!-- Guarantee -->
  <section class="section bg-white">
    <div class="section-narrow">
      <div class="bg-slate-50 border-2 border-pth-green rounded-lg p-6 md:p-8 shadow-sm">
        <p class="text-pth-green font-bold uppercase tracking-wide text-sm mb-2">🛡 Better-Than-Amazon Guarantee</p>
        <h3 class="text-xl md:text-2xl font-extrabold">
          Watch a single session. If you don't pick up at least three usable moves, write us and we'll refund every cent.
        </h3>
      </div>
    </div>
  </section>

  <!-- Price + CTA -->
  <section class="section bg-white pb-16">
    <div class="section-narrow text-center">
      <p class="text-base md:text-lg font-bold uppercase tracking-wide text-slate-600 mb-2">
        What Dan Charges Per Session: <span class="line-through decoration-2">$650/hr</span>
      </p>
      <p class="text-base md:text-lg font-bold uppercase tracking-wide text-slate-600">Your Price On This Page Only:</p>
      <p class="text-6xl md:text-8xl font-extrabold text-pth-blue mt-2 mb-8">${downsellAmount}</p>

      <button id="yes-btn" type="button"
        class="w-full bg-pth-orange hover:bg-pth-orange-dark text-white font-extrabold uppercase tracking-wide text-lg md:text-xl px-6 py-5 rounded-md shadow-lg transition disabled:opacity-60 disabled:cursor-not-allowed">
        <span data-idle>Yes! Add The Recordings For ${downsellAmount} →</span>
        <span data-busy class="hidden">Charging Your Card…</span>
      </button>
      <p class="mt-3 text-sm text-slate-600">
        One click — we'll charge the card you used a moment ago. No need to re-enter anything.
      </p>

      <a id="no-btn" href={`/thank-you?order=${encodeURIComponent(orderToken)}`}
        class="mt-6 inline-block text-sm text-slate-500 underline underline-offset-4 hover:text-slate-700">
        No thanks — finish my order
      </a>

      <p id="err" class="hidden mt-4 text-sm text-pth-red" role="alert"></p>
    </div>
  </section>

  <script is:inline define:vars={{ orderToken }}>
  (function () {
    const yes = document.getElementById('yes-btn');
    const err = document.getElementById('err');
    if (!yes) return;
    yes.addEventListener('click', async () => {
      err.classList.add('hidden'); err.textContent = '';
      const idle = yes.querySelector('[data-idle]');
      const busy = yes.querySelector('[data-busy]');
      yes.disabled = true; idle.classList.add('hidden'); busy.classList.remove('hidden');
      try {
        const r = await fetch('/api/downsell', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ order_token: orderToken }),
        });
        const data = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(data.error || `Downsell charge failed (${r.status})`);
        window.location.href = `/thank-you?order=${encodeURIComponent(orderToken)}&downsell=1`;
      } catch (e) {
        err.textContent = e.message || 'Could not complete the charge. Try again or skip.';
        err.classList.remove('hidden');
        yes.disabled = false; idle.classList.remove('hidden'); busy.classList.add('hidden');
      }
    });
  })();
  </script>
</BaseLayout>
