# ============================================================================
# pth-funnel — environment variables
# Copy to .env (gitignored) and fill in real values.
# ============================================================================

# ---- Lead capture (popup form on the sales page) ---------------------------
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME
GHL_OPTIN_TAG=pth-sales-page-optin
PUBLIC_CHECKOUT_URL=/checkout

# ---- Stripe (PLACEHOLDERS until real keys are provisioned) -----------------
STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_REPLACE_ME
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER_REPLACE_ME
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_PLACEHOLDER_REPLACE_ME

# ---- Product pricing (USD cents) -------------------------------------------
PRODUCT_MAIN_NAME=The Part-Time Hypnotist
PRODUCT_MAIN_AMOUNT_CENTS=1495
PRODUCT_UPSELL_NAME=Self Hypnosis Secrets
PRODUCT_UPSELL_AMOUNT_CENTS=19700
PRODUCT_DOWNSELL_NAME=Live Client Recordings
PRODUCT_DOWNSELL_AMOUNT_CENTS=2700

# ---- Order token signing ---------------------------------------------------
# Generate with: openssl rand -hex 32
ORDER_TOKEN_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- GHL webhooks fired after successful purchases -------------------------
GHL_BUYER_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_BUYER
GHL_UPSELL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_UPSELL
GHL_DOWNSELL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_DOWNSELL

# ---- Preview bypass (NOT for production launch) ----------------------------
# Set to 1 to allow `?preview=1` to skip the order-token check on /upsell and
# /downsell so the team can review the pages without going through Stripe.
# REMOVE or set to 0 before opening the funnel to real customers.
ALLOW_PREVIEW_BYPASS=0
