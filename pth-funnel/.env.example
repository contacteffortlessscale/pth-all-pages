# ============================================================================
# pth-funnel — environment variables
# Copy to .env (gitignored) and fill in real values.
# ============================================================================

# ---- Lead capture (popup form on the sales page) ---------------------------
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME
GHL_OPTIN_TAG=pth-sales-page-optin
PUBLIC_CHECKOUT_URL=/checkout

# ---- Stripe LIVE (real money) ----------------------------------------------
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# ---- Stripe TEST (only used when mode is flipped to "test") ----------------
# These let an admin run end-to-end tests with 4242 4242 4242 4242 without
# real charges. The mode is toggled at /admin/stripe-mode and stored in KV.
STRIPE_TEST_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ---- Stripe mode override (optional) ---------------------------------------
# If set to "live" or "test", this OVERRIDES the KV-stored mode for the whole
# site. Useful as an escape hatch if KV is broken or you want to lock the mode
# for a particular deploy. Leave UNSET to use the admin-page toggle.
# STRIPE_MODE=

# ---- Admin (Stripe mode toggle) --------------------------------------------
# Comma-separated list of emails allowed to log into /admin/stripe-mode.
ADMIN_EMAILS=contact.effortlessscale@gmail.com,zac@zachansen.com
# GHL Inbound Webhook URL that sends the 6-digit OTP email. The workflow
# behind it should: trigger on inbound webhook → Send Email action whose body
# contains the OTP at {{inboundWebhookRequest.otp_code}}.
ADMIN_OTP_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_ADMIN_OTP
# Random hex used to sign admin cookies. Generate with: openssl rand -hex 32
ADMIN_COOKIE_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- Product pricing (USD cents) -------------------------------------------
PRODUCT_MAIN_NAME=The Part-Time Hypnotist
PRODUCT_MAIN_AMOUNT_CENTS=1495
PRODUCT_UPSELL_NAME=Self Hypnosis Secrets
PRODUCT_UPSELL_AMOUNT_CENTS=19700
PRODUCT_DOWNSELL_NAME=Live Client Recordings
PRODUCT_DOWNSELL_AMOUNT_CENTS=2700

# ---- Order token signing ---------------------------------------------------
# Generate with: openssl rand -hex 32
ORDER_TOKEN_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ---- GHL webhooks fired after successful purchases -------------------------
GHL_BUYER_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_BUYER
GHL_UPSELL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_UPSELL
GHL_DOWNSELL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME_DOWNSELL

# ---- Preview bypass (NOT for production launch) ----------------------------
# Set to 1 to allow `?preview=1` to skip the order-token check on /upsell and
# /downsell so the team can review the pages without going through Stripe.
# REMOVE or set to 0 before opening the funnel to real customers.
ALLOW_PREVIEW_BYPASS=0
