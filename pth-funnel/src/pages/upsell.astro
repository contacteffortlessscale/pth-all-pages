---
// /upsell — serves the original "Self Hypnosis Secrets" HTML with a small
// splice script that rewires the YES button to /api/upsell (off-session
// Stripe charge) and the "No thanks" link to /thank-you. Everything else on
// the page (visuals, copy, video, layout) is the original verbatim.
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { verifyOrderToken } from '../lib/orderToken';

export const prerender = false;

const orderToken = Astro.url.searchParams.get('order') || '';
const payload = orderToken ? verifyOrderToken(orderToken) : null;
const isPreview = Astro.url.searchParams.get('preview') === '1'
  && (import.meta.env.DEV || import.meta.env.ALLOW_PREVIEW_BYPASS === '1');

if (!payload && !isPreview) {
  return Astro.redirect('/checkout');
}

let html = readFileSync(path.join(process.cwd(), 'src/raw/upsell.html'), 'utf8');

// Splice script injected just before </body>.
const splice = `
<script>
(function () {
  var ORDER_TOKEN = ${JSON.stringify(orderToken)};
  var IS_PREVIEW  = ${isPreview ? 'true' : 'false'};
  var THANK_YOU   = '/thank-you?order=' + encodeURIComponent(ORDER_TOKEN || '');

  // --- helpers ---
  function visibleText(el) { return (el.textContent || '').replace(/\\s+/g, ' ').trim(); }

  function looksLikeYesButton(el) {
    if (!el || !el.tagName) return false;
    var tag = el.tagName.toLowerCase();
    if (tag !== 'button' && tag !== 'a' && tag !== 'div' && tag !== 'span') return false;
    var t = visibleText(el).toLowerCase();
    if (!t) return false;
    // Match "yes", "i want", "add", "claim"-style accept CTAs
    return /\\byes\\b.*(add|want|claim|access|order|upgrade)|\\bi want\\b|\\badd to my order\\b|\\bunlock\\b/.test(t);
  }

  function looksLikeNoThanksLink(el) {
    if (!el || !el.tagName) return false;
    var tag = el.tagName.toLowerCase();
    if (tag !== 'a' && tag !== 'button' && tag !== 'span' && tag !== 'div') return false;
    var t = visibleText(el).toLowerCase();
    return /\\bno thanks\\b|\\bno, ?i/.test(t);
  }

  function chargeUpsell(e) {
    if (e) { e.preventDefault(); e.stopPropagation(); }
    if (IS_PREVIEW) {
      alert('Preview mode — the Yes button would call /api/upsell here.');
      window.location.href = THANK_YOU + '&upsell=1';
      return;
    }
    if (!ORDER_TOKEN) {
      alert('Missing order token. Please complete checkout first.');
      window.location.href = '/checkout';
      return;
    }
    fetch('/api/upsell', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order_token: ORDER_TOKEN }),
    })
      .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
      .then(function (res) {
        if (!res.ok) throw new Error((res.d && res.d.error) || 'Upsell failed');
        window.location.href = THANK_YOU + '&upsell=1';
      })
      .catch(function (err) {
        alert('Could not complete the charge: ' + (err && err.message ? err.message : 'unknown error'));
      });
  }

  function declineUpsell(e) {
    if (e) { e.preventDefault(); e.stopPropagation(); }
    window.location.href = THANK_YOU;
  }

  // --- rewire on first match, then keep watching for re-renders ---
  var wiredYes = false, wiredNo = false;
  function scan() {
    if (!wiredYes) {
      var nodes = document.querySelectorAll('button, a, div, span');
      for (var i = 0; i < nodes.length; i++) {
        if (looksLikeYesButton(nodes[i])) {
          var btn = nodes[i];
          // capture-phase listener so we intercept BEFORE GHL's own handlers
          btn.addEventListener('click', chargeUpsell, true);
          btn.style.cursor = 'pointer';
          wiredYes = true;
          break;
        }
      }
    }
    if (!wiredNo) {
      var links = document.querySelectorAll('a, button, span, div');
      for (var j = 0; j < links.length; j++) {
        if (looksLikeNoThanksLink(links[j])) {
          var lnk = links[j];
          lnk.addEventListener('click', declineUpsell, true);
          if (lnk.tagName.toLowerCase() === 'a') lnk.setAttribute('href', THANK_YOU);
          wiredNo = true;
          break;
        }
      }
    }
  }

  function start() {
    scan();
    // SPA hydrates after initial DOM — keep watching for ~10s in case the
    // buttons appear later.
    var observer = new MutationObserver(scan);
    observer.observe(document.body, { childList: true, subtree: true });
    setTimeout(function () { observer.disconnect(); }, 10000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }
})();
</script>
`;

// Inject before </body>.
if (html.indexOf('</body>') !== -1) {
  html = html.replace('</body>', splice + '</body>');
} else {
  html += splice;
}

return new Response(html, {
  status: 200,
  headers: { 'Content-Type': 'text/html; charset=utf-8' },
});
---
