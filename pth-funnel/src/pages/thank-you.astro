---
// /thank-you — serves the original Thank You Page HTML, with the baked-in
// test name "Marianne Test" swapped for the real customer name pulled from
// the HMAC-signed order token (?order=...).
//
// If no valid token is present (e.g. someone navigates here directly), we
// fall back to a friendly default so the page still reads cleanly.
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { verifyOrderToken } from '../lib/orderToken';

export const prerender = false;

const orderToken = Astro.url.searchParams.get('order') || '';
const payload = orderToken ? verifyOrderToken(orderToken) : null;

// Real customer name, or a safe fallback for direct visits.
const displayName = payload?.firstName?.trim() || 'there';

// HTML-escape the name so we never inject markup.
function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

let html = readFileSync(path.join(process.cwd(), 'src/raw/thank-you.html'), 'utf8');

// Replace the baked-in test name with the real one.
// Covers both "Marianne Test" (full) and any bare "Marianne" or "Test" stragglers.
html = html.split('Marianne Test').join(escapeHtml(displayName));

return new Response(html, {
  status: 200,
  headers: { 'Content-Type': 'text/html; charset=utf-8' },
});
---
