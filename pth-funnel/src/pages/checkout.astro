---
// /checkout — serves the original GHL checkout HTML with a splice script
// that:
//   1. Loads Stripe.js
//   2. Waits for the GHL payment form (form.form-payment.order-form-v2)
//   3. Hides it and inserts our own Stripe Elements form in its place
//   4. On submit, creates a Stripe Customer + PaymentMethod via /api/checkout
//      and redirects to /upsell?order=<token>
//
// Everything else on the page (header, copy, order summary, guarantee,
// "Here's everything you're getting", footer) is the original verbatim.
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { getStripeMode, getStripeKeys } from '../lib/stripeMode';

export const prerender = false;

// Resolve the active Stripe mode (live vs test) for THIS request, then pick
// the publishable key that matches. The mode comes from Vercel KV (set via
// /admin/stripe-mode) or the STRIPE_MODE env-var override.
const { mode: stripeMode } = await getStripeMode();
const keys = getStripeKeys(stripeMode);
const publishableKey = keys.publishable || 'pk_test_PLACEHOLDER_REPLACE_ME';
const productAmountCents = Number(process.env.PRODUCT_MAIN_AMOUNT_CENTS || 1495);
const productAmount = (productAmountCents / 100).toFixed(2);

let html = readFileSync(path.join(process.cwd(), 'src/raw/checkout.html'), 'utf8');

const splice = `
<style>
  #pth-stripe-shell { max-width: 560px; margin: 24px auto; padding: 24px; border: 1px solid #e2e6f0; border-radius: 10px; background: #fff; box-shadow: 0 6px 24px rgba(15,23,42,0.06); font-family: Inter, system-ui, -apple-system, "Segoe UI", sans-serif; color: #0f172a; }
  #pth-stripe-shell h2 { margin: 0 0 16px; font-size: 18px; font-weight: 700; }
  #pth-stripe-shell .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  #pth-stripe-shell label { display: flex; flex-direction: column; gap: 6px; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #475569; }
  #pth-stripe-shell input[type=text], #pth-stripe-shell input[type=email] { padding: 12px 14px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 16px; color: #0f172a; font-family: inherit; background: #fff; }
  #pth-stripe-shell input[type=text]:focus, #pth-stripe-shell input[type=email]:focus { outline: none; border-color: #188bf6; box-shadow: 0 0 0 3px rgba(24,139,246,0.18); }
  #pth-stripe-shell .card-wrap { padding: 12px 14px; border: 1px solid #cbd5e1; border-radius: 6px; background: #fff; }
  #pth-stripe-card { min-height: 22px; }
  #pth-stripe-shell .submit { width: 100%; margin-top: 16px; padding: 16px 20px; background: #f6ad55; color: #fff; border: 0; border-radius: 6px; font-size: 18px; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; cursor: pointer; transition: background 120ms; }
  #pth-stripe-shell .submit:hover { background: #dd8b2c; }
  #pth-stripe-shell .submit:disabled { opacity: 0.6; cursor: not-allowed; }
  #pth-stripe-shell .err { display: none; margin-top: 10px; color: #e93d3d; font-size: 14px; text-align: center; }
  #pth-stripe-shell .micro { margin-top: 10px; font-size: 12px; text-align: center; color: #64748b; }
</style>
<template id="pth-stripe-template">
  <div id="pth-stripe-shell">
    <h2>Secure Payment · Powered by Stripe</h2>
    <div class="row">
      <label>First name<input type="text" id="pth-first-name" autocomplete="given-name" required /></label>
      <label>Email<input type="email" id="pth-email" autocomplete="email" required /></label>
    </div>
    <label>Card details<div class="card-wrap"><div id="pth-stripe-card"></div></div></label>
    <button type="button" class="submit" id="pth-pay-btn">
      <span data-idle>Complete order — $${productAmount}</span>
      <span data-busy style="display:none">Processing…</span>
    </button>
    <p class="err" id="pth-pay-err"></p>
    <p class="micro">Your card details are sent directly to Stripe. We never see or store them.</p>
  </div>
</template>
<script>
(function () {
  var PUBLISHABLE_KEY = ${JSON.stringify(publishableKey)};
  var PRODUCT_AMOUNT  = ${JSON.stringify(productAmount)};
  var STRIPE_MODE     = ${JSON.stringify(stripeMode)};

  // GHL serves a proxied Stripe.js from /refs/checkout/v3 on its own domain.
  // Stripe.js has a hard "must be loaded from js.stripe.com" guard that throws
  // when the active instance came from anywhere else, and a "don't re-init if
  // already loaded" guard that prevents a second <script src="js.stripe.com/v3/">
  // from replacing the global. To get a clean Stripe instance we have to:
  //   1. Remove the GHL-proxied script tag(s) from the DOM
  //   2. Wipe Stripe globals
  //   3. Then load the canonical js.stripe.com/v3/ ourselves
  function ensureCleanStripe(done) {
    if (window.Stripe && window.Stripe.__pthClean) { done(); return; }
    var existing = document.querySelectorAll(
      'script[src*="stripe.com/v3"], script[src*="/refs/checkout/v3"]'
    );
    for (var i = 0; i < existing.length; i++) {
      try { existing[i].parentNode && existing[i].parentNode.removeChild(existing[i]); } catch (_) {}
    }
    try { delete window.Stripe; } catch (_) { window.Stripe = undefined; }
    try { delete window.StripeM; } catch (_) {}

    var s = document.createElement('script');
    s.src = 'https://js.stripe.com/v3/';
    s.async = true;
    s.onload = function () {
      if (!window.Stripe) {
        console.error('[pth-checkout] Stripe.js loaded but window.Stripe is undefined');
        return;
      }
      try { window.Stripe.__pthClean = true; } catch (_) {}
      done();
    };
    s.onerror = function () {
      var errEl = document.getElementById('pth-pay-err');
      if (errEl) { errEl.style.display = 'block'; errEl.textContent = 'Failed to load Stripe.js. Please refresh.'; }
    };
    document.head.appendChild(s);
  }

  function init() {
    var ghlForm = document.querySelector('form.form-payment.order-form-v2');
    if (!ghlForm) return false;

    // Hide the original GHL payment form.
    ghlForm.style.display = 'none';

    // Hide the duplicate "Contact & Shipping Information" section (name + email
    // inputs) that sits above the payment form — our Stripe shell collects
    // these fields itself, prefilled from URL params.
    var infoSection = ghlForm.parentNode && ghlForm.parentNode.querySelector('section.info');
    if (infoSection) infoSection.style.display = 'none';

    // Hide the original "Payment" heading bar — our Stripe shell has its own.
    var paymentTitle = ghlForm.parentNode && ghlForm.parentNode.querySelector('.payment-title-wrapp');
    if (paymentTitle) paymentTitle.style.display = 'none';

    // Insert our Stripe form in its place.
    var tpl = document.getElementById('pth-stripe-template');
    if (!tpl) return false;
    var node = tpl.content.firstElementChild.cloneNode(true);
    ghlForm.parentNode.insertBefore(node, ghlForm);

    // Pre-fill from URL params (passed by the sales-page popup).
    try {
      var params = new URLSearchParams(window.location.search);
      var qf = params.get('first_name'), qe = params.get('email');
      if (qf) document.getElementById('pth-first-name').value = qf;
      if (qe) document.getElementById('pth-email').value = qe;
    } catch (_) {}

    // Log the publishable key prefix so we can verify in DevTools what the
    // built bundle actually has (real keys start with "pk_test_" or "pk_live_"
    // followed by a long random string; the placeholder is the literal string
    // "pk_test_PLACEHOLDER_REPLACE_ME").
    try { console.log('[pth-checkout] Stripe mode:', STRIPE_MODE, '| publishable key prefix:', (PUBLISHABLE_KEY || '').slice(0, 12) + '…'); } catch (_) {}

    // Render a small banner at the top of our Stripe shell when in TEST mode,
    // so it's impossible to confuse a real customer flow with a test one.
    if (STRIPE_MODE === 'test') {
      var shell = document.getElementById('pth-stripe-shell');
      if (shell) {
        var banner = document.createElement('div');
        banner.style.cssText = 'margin: -12px 0 16px; padding: 8px 12px; background: #fef3c7; color: #78350f; border: 1px solid #f59e0b; border-radius: 6px; font-size: 12px; font-weight: 700; text-align: center; letter-spacing: 0.04em; text-transform: uppercase;';
        banner.textContent = '⚠ Test mode — use 4242 4242 4242 4242';
        shell.insertBefore(banner, shell.firstChild.nextSibling);
      }
    }

    // Bail loudly if the build inlined the placeholder key (PUBLIC_STRIPE_PUBLISHABLE_KEY
    // was empty at build time). Mounting card Elements with a placeholder produces
    // a silently-empty iframe, which is what you'd otherwise see.
    if (!PUBLISHABLE_KEY || PUBLISHABLE_KEY.indexOf('PLACEHOLDER') !== -1 || !/^pk_(test|live)_[A-Za-z0-9]{8,}/.test(PUBLISHABLE_KEY)) {
      var errEl = document.getElementById('pth-pay-err');
      errEl.style.display = 'block';
      errEl.textContent = 'Stripe publishable key not configured. Set PUBLIC_STRIPE_PUBLISHABLE_KEY in Vercel and redeploy.';
      var cardWrap = document.querySelector('#pth-stripe-shell .card-wrap');
      if (cardWrap) cardWrap.style.display = 'none';
      var payBtn = document.getElementById('pth-pay-btn');
      if (payBtn) payBtn.disabled = true;
      return true;
    }

    // Load Stripe.js cleanly (kicking out GHL's proxied copy), then mount.
    ensureCleanStripe(function () {
      var stripe = window.Stripe(PUBLISHABLE_KEY);
      var elements = stripe.elements();
      var card = elements.create('card', {
        style: {
          base: { color: '#0f172a', fontFamily: 'Inter, system-ui, sans-serif', fontSize: '16px', '::placeholder': { color: '#94a3b8' } },
          invalid: { color: '#e93d3d', iconColor: '#e93d3d' },
        },
      });
      card.mount('#pth-stripe-card');

      var btn = document.getElementById('pth-pay-btn');
      var err = document.getElementById('pth-pay-err');
      function setBusy(busy) {
        btn.disabled = busy;
        btn.querySelector('[data-idle]').style.display = busy ? 'none' : '';
        btn.querySelector('[data-busy]').style.display = busy ? '' : 'none';
      }

      btn.addEventListener('click', function () {
        err.style.display = 'none'; err.textContent = '';
        var first_name = document.getElementById('pth-first-name').value.trim();
        var email      = document.getElementById('pth-email').value.trim();
        if (!first_name || !email) {
          err.textContent = 'Please fill in your name and email.';
          err.style.display = 'block';
          return;
        }
        setBusy(true);
        stripe.createPaymentMethod({
          type: 'card', card: card,
          billing_details: { name: first_name, email: email },
        }).then(function (pm) {
          if (pm.error) throw new Error(pm.error.message || 'Card error');
          return fetch('/api/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ first_name: first_name, email: email, payment_method_id: pm.paymentMethod.id }),
          }).then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); });
        }).then(function (res) {
          if (!res.ok) throw new Error((res.d && res.d.error) || 'Checkout failed');
          if (res.d.requires_action && res.d.payment_intent_client_secret) {
            return stripe.confirmCardPayment(res.d.payment_intent_client_secret).then(function (a) {
              if (a.error) throw new Error(a.error.message || 'Card authentication failed');
              window.location.href = '/upsell?order=' + encodeURIComponent(res.d.order_token);
            });
          }
          if (!res.d.order_token) throw new Error('Server did not return an order token.');
          window.location.href = '/upsell?order=' + encodeURIComponent(res.d.order_token);
        }).catch(function (e) {
          err.textContent = e.message || 'Something went wrong. Please try again.';
          err.style.display = 'block';
          setBusy(false);
        });
      });
    });

    return true;
  }

  function start() {
    if (init()) return;
    var observer = new MutationObserver(function () { if (init()) observer.disconnect(); });
    observer.observe(document.body, { childList: true, subtree: true });
    setTimeout(function () { observer.disconnect(); }, 15000);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }
})();
</script>
`;

if (html.indexOf('</body>') !== -1) {
  html = html.replace('</body>', splice + '</body>');
} else {
  html += splice;
}

return new Response(html, {
  status: 200,
  headers: { 'Content-Type': 'text/html; charset=utf-8' },
});
---
