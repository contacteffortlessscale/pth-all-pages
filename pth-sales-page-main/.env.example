# GoHighLevel inbound webhook URL — the workflow trigger that creates the contact.
# Get this from GHL → Automation → Workflows → new "Inbound Webhook" trigger.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/REPLACE_ME

# Where the page's CTA buttons + popup "Step #2" should send the user.
# This is the existing GHL checkout URL — payments stay in GHL.
PUBLIC_CHECKOUT_URL=https://theparttimehypnotist.com/REPLACE-ME-checkout

# Optional: tag(s) to apply to the contact in GHL on opt-in.
GHL_OPTIN_TAG=pth-sales-page-optin
